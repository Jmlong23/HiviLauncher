<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/launcher_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#363636"
    android:orientation="vertical"
    android:paddingLeft="33dp"
    android:paddingRight="33dp"
    android:paddingTop="23dp"
    android:paddingBottom="35dp">

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="35dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="13dp">

        <LinearLayout
            android:id="@+id/wifi_status_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/wifi_icon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_wifi" />

            <Space
                android:id="@+id/wifi_icon_text_gap"
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/wifi_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:text="@string/main_disconnected"
                android:textColor="@color/text_color"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Space
            android:id="@+id/wifi_bt_gap"
            android:layout_width="24dp"
            android:layout_height="1dp" />

        <LinearLayout
            android:id="@+id/bluetooth_status_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/bluetooth_icon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_bt" />

            <Space
                android:id="@+id/bluetooth_icon_text_gap"
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/bluetooth_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:text="@string/main_disconnected"
                android:textColor="@color/text_color"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Space
            android:id="@+id/top_bar_filler"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:orientation="horizontal"
            android:background="@drawable/main_status_pill_background"
            android:gravity="center">

            <ImageView
                android:id="@+id/account_img"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:background="@color/white"
                android:paddingLeft="13dp"/>

            <TextView
                android:id="@+id/account_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/main_account"
                android:textColor="@color/text_color"
                android:textSize="15sp"
                android:paddingLeft="7dp"
                android:paddingRight="13dp"
                android:drawableEnd="@drawable/main_account_indicator"
                android:drawablePadding="8dp" />
        </LinearLayout>


        <TextView
            android:id="@+id/mode_text"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:background="@drawable/main_status_pill_background"
            android:gravity="center"
            android:text="@string/main_current_mode_wifi"
            android:textColor="@color/text_color"
            android:textSize="15sp"
            android:paddingRight="20dp"
            android:paddingLeft="20dp"
            android:layout_marginLeft="25dp"
            android:drawableEnd="@drawable/ic_switch_mode"
            android:drawablePadding="8dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:orientation="horizontal"
        android:gravity="center">
        <View
            android:layout_width="139dp"
            android:layout_height="0.5dp"
            android:background="#C5C6C6"
            android:layout_marginRight="14dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/select_mode"
            android:textSize="20sp"
            android:textColor="@color/text_color"
            android:layout_marginRight="14dp"/>
        <View
            android:layout_width="139dp"
            android:layout_height="0.5dp"
            android:background="#C5C6C6"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/cards_row"
        android:layout_width="match_parent"
        android:layout_height="231dp"
        android:layout_marginTop="47dp"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingLeft="30dp"
        android:paddingRight="30dp"
        android:scrollbars="none" />


</LinearLayout>

